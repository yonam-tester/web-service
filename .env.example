# ──────────────────────────────────────────────
# 백엔드 → AI 서버 연결
# ──────────────────────────────────────────────
AI_SERVER_URL=http://rag-server:8000

# ──────────────────────────────────────────────
# LLM 공급자 설정
# llm.provider: mock | bedrock
# llm.direct: true(백엔드 직접 Bedrock 호출) | false(RAG 서버 위임)
# ──────────────────────────────────────────────
LLM_PROVIDER=bedrock
LLM_DIRECT=true

# ──────────────────────────────────────────────
# AWS (Bedrock + S3)
# EC2 IAM Role 사용 시 KEY/SECRET 비워두면 자동 인증
# ──────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ──────────────────────────────────────────────
# S3 스토리지
# 실제 AWS S3 사용 시 ENDPOINT 제거 또는 비워둠
# MinIO 로컬 사용 시: http://minio:9000
# ──────────────────────────────────────────────
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_BUCKET_DOCUMENTS=yeonam-documents
AWS_S3_BUCKET_REPORTS=yeonam-reports

# ──────────────────────────────────────────────
# RAG 서버 설정
# ──────────────────────────────────────────────
MOCK_LLM=false
MOCK_RAG=false
BACKEND_URL=http://backend:8080
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OPENAI_API_KEY=sk-...   # MOCK_LLM=false 시 필요 (또는 프론트에서 입력)
